# Bizquip — Results Dashboard (hand-made mode via n8n SQL webhook)
# Deploy n8n/Bizquip Results Engine - KPI Feed.json on the Bizquip n8n, then fill these.
# NOTE: the Bizquip n8n is served over HTTP (not HTTPS) — keep the scheme as http.

# Full webhook URL (used directly if the proxy is off):
VITE_BIZQUIP_WEBHOOK_URL=http://automation-bizquip.braind.io/webhook/bizquip-results-engine

# Split for the Vite dev proxy (/feed) — recommended (avoids browser CORS):
VITE_BIZQUIP_WEBHOOK_BASE=http://automation-bizquip.braind.io
VITE_BIZQUIP_WEBHOOK_PATH=/webhook/bizquip-results-engine

# Route the feed through a same-origin /feed proxy. Recommended: "1".
# This avoids browser mixed-content (the webhook is HTTP, the site is HTTPS) and CORS.
#   - In dev,  /feed is served by the Vite dev-server proxy (vite.config.js).
#   - In prod, YOU must add a host rewrite so /feed exists. On AWS Amplify:
#       Hosting → Rewrites and redirects → add:
#         Source  /feed
#         Target  http://automation-bizquip.braind.io/webhook/bizquip-results-engine
#         Type    200 (Rewrite)
#       Put this rule ABOVE any SPA catch-all (/<*> → /index.html).
#     Without it the deployed app gets "Feed returned HTTP 404".
VITE_BIZQUIP_USE_PROXY=1
